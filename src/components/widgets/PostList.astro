---
import type { PostListProps } from '@/types'
import { themeConfig } from '@/config'

const { posts } = Astro.props as PostListProps

const DOW = ['일', '월', '화', '수', '목', '금', '토']

const grouped = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const d = new Date(post.data.pubDate)
  const key = String(d.getFullYear())
  if (!acc[key]) acc[key] = []
  acc[key].push(post)
  return acc
}, {})

const groupKeys = Object.keys(grouped).sort().reverse()

function shortDate(date: Date) {
  return `${date.getMonth() + 1}. ${date.getDate()} (${DOW[date.getDay()]})`
}
---

<div class="post-list">
  {
    groupKeys.map((year) => (
      <div class="year-group" data-year={year}>
        <p class="year-header font-features" data-year-toggle={year}>
          <span class="year-header-left">
            {year}
            <span class="year-count">글 {grouped[year].length}개</span>
          </span>
          <svg class="year-arrow" data-year-arrow={year} width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
            <path d="M3 2l4 3-4 3V2z" />
          </svg>
        </p>
        <ul data-year-list={year}>
          {grouped[year].map((post) => {
            const d = new Date(post.data.pubDate)
            return (
              <li data-tags={post.data.tags?.join(',') ?? ''}>
                <a href={`/${post.id}/`}>
                  <div class={`post-item ${!themeConfig.date.dateOnRight ? 'date-left' : ''}`}>
                    {!themeConfig.date.dateOnRight && <p class="date font-features">{shortDate(d)}</p>}
                    <p class="title">
                      {post.data.category === '책' && (
                        <svg class="cat-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
                          <path d="M384 128C384 145.7 369.7 160 352 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L352 96C369.7 96 384 110.3 384 128zM384 384C384 401.7 369.7 416 352 416L128 416C110.3 416 96 401.7 96 384C96 366.3 110.3 352 128 352L352 352C369.7 352 384 366.3 384 384zM96 256C96 238.3 110.3 224 128 224L512 224C529.7 224 544 238.3 544 256C544 273.7 529.7 288 512 288L128 288C110.3 288 96 273.7 96 256zM544 512C544 529.7 529.7 544 512 544L128 544C110.3 544 96 529.7 96 512C96 494.3 110.3 480 128 480L512 480C529.7 480 544 494.3 544 512z"/>
                        </svg>
                      )}
                      {post.data.category === '영화' && (
                        <svg class="cat-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
                          <path d="M320 112C434.9 112 528 205.1 528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112zM320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM276.5 211.5C269.1 207 259.8 206.8 252.2 211C244.6 215.2 240 223.3 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4zM362 320L288 365.2L288 274.8L362 320z"/>
                        </svg>
                      )}
                      {post.data.title}
                    </p>
                    {themeConfig.date.dateOnRight && (
                      <div class={themeConfig.general.postListDottedDivider ? 'dotted-divider' : 'divider'} />
                    )}
                    {themeConfig.date.dateOnRight && <p class="date font-features">{shortDate(d)}</p>}
                  </div>
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    ))
  }
</div>
<div class="placeholder"></div>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .year-group {
    margin-bottom: 1rem;
  }

  .year-header {
    margin: 0 0 0.1rem;
    font-size: var(--font-size-s);
    color: var(--text-tertiary);
    letter-spacing: var(--spacing-s);
    opacity: 0.75;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }

  .year-header:hover {
    opacity: 1;
  }

  .year-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .year-count {
    font-size: 0.9em;
    opacity: 0.85;
  }

  .year-arrow {
    opacity: 0.5;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(90deg);
    flex-shrink: 0;
  }

  .year-arrow.collapsed {
    transform: rotate(0deg);
  }

  ul[data-year-list] {
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  a {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover a {
      opacity: 0.4;
    }

    ul:hover a:hover {
      opacity: 1;
    }

    ul:hover a:hover .divider {
      background-color: var(--text-tertiary);
      opacity: 0.75;
    }
    ul:hover a:hover .dotted-divider {
      color: var(--text-secondary);
    }
    ul:hover a:hover .date {
      color: var(--text-secondary);
      opacity: 1;
    }
  }

  .post-item {
    height: 2.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .post-item.date-left {
    justify-content: flex-start;
  }

  .post-item.date-left .title {
    flex: 1 1 auto;
    min-width: 0;
  }

  .post-item.date-left .date {
    margin-right: 0.75rem;
  }

  .title {
    margin: 0;
    flex-shrink: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .cat-icon {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    opacity: 0.5;
  }

  .date {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: var(--spacing-s);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .divider {
    flex: 1 1 auto;
    min-width: 3rem;
    margin: 0 0.25rem;
    height: 0.5px;
    background-color: var(--border);
  }

  .dotted-divider {
    flex: 1 1 3rem;
    min-width: 3rem;
    max-width: 100%;
    text-align: end;
    letter-spacing: 5px;
    height: 1.675rem;
    line-height: 1.675rem;
    overflow: hidden;
    color: var(--text-tertiary);
    opacity: 0.75;
  }

  .dotted-divider::after {
    content: '·····························································································································································';
    pointer-events: none;
  }

  .placeholder {
    height: 3rem;
  }

  @media (max-width: 768px) {
    .post-item {
      height: 1.875rem;
    }

    .dotted-divider {
      height: 1.875rem;
      line-height: 1.875rem;
    }

    .placeholder {
      height: 1.5rem;
    }
  }
</style>

<script is:inline>
  function initYearAccordion() {
    const currentYear = String(new Date().getFullYear())

    document.querySelectorAll('[data-year-list]').forEach((ul) => {
      const year = ul.getAttribute('data-year-list')
      const arrow = document.querySelector(`[data-year-arrow="${year}"]`)
      const isCurrentYear = year === currentYear

      if (isCurrentYear) {
        ul.style.maxHeight = ul.scrollHeight + 'px'
      } else {
        ul.style.maxHeight = '0'
        arrow?.classList.add('collapsed')
      }
    })

    document.querySelectorAll('[data-year-toggle]').forEach((header) => {
      header.addEventListener('click', () => {
        const year = header.getAttribute('data-year-toggle')
        const ul = document.querySelector(`[data-year-list="${year}"]`)
        const arrow = document.querySelector(`[data-year-arrow="${year}"]`)
        const isOpen = ul.style.maxHeight !== '0px' && ul.style.maxHeight !== ''

        if (isOpen) {
          ul.style.maxHeight = '0'
          arrow?.classList.add('collapsed')
        } else {
          ul.style.maxHeight = ul.scrollHeight + 'px'
          arrow?.classList.remove('collapsed')
        }
      })
    })
  }

  document.addEventListener('astro:page-load', initYearAccordion)
</script>
