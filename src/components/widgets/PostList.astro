---
import type { PostListProps } from '@/types'
import { themeConfig } from '@/config'

const { posts } = Astro.props as PostListProps

const DOW = ['일', '월', '화', '수', '목', '금', '토']

const grouped = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const d = new Date(post.data.pubDate)
  const key = String(d.getFullYear())
  if (!acc[key]) acc[key] = []
  acc[key].push(post)
  return acc
}, {})

const groupKeys = Object.keys(grouped).sort().reverse()

function shortDate(date: Date) {
  return `${date.getMonth() + 1}. ${date.getDate()} (${DOW[date.getDay()]})`
}
---

<div class="post-list">
  {
    groupKeys.map((year) => (
      <div class="year-group" data-year={year}>
        <p class="year-header font-features" data-year-toggle={year}>
          <span class="year-header-left">
            {year}
            <span class="year-count">글 {grouped[year].length}개</span>
          </span>
          <svg class="year-arrow" data-year-arrow={year} width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
            <path d="M3 2l4 3-4 3V2z" />
          </svg>
        </p>
        <ul data-year-list={year}>
          {grouped[year].map((post) => {
            const d = new Date(post.data.pubDate)
            return (
              <li data-tags={post.data.tags?.join(',') ?? ''}>
                <a href={`/${post.id}/`}>
                  <div class={`post-item ${!themeConfig.date.dateOnRight ? 'date-left' : ''}`}>
                    {!themeConfig.date.dateOnRight && <p class="date font-features">{shortDate(d)}</p>}
                    <p class="title">
                      {post.data.category === '책' && (
                        <svg class="cat-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
                          <path d="M480 576L192 576C139 576 96 533 96 480L96 160C96 107 139 64 192 64L496 64C522.5 64 544 85.5 544 112L544 400C544 420.9 530.6 438.7 512 445.3L512 512C529.7 512 544 526.3 544 544C544 561.7 529.7 576 512 576L480 576zM192 448C174.3 448 160 462.3 160 480C160 497.7 174.3 512 192 512L448 512L448 448L192 448zM224 216C224 229.3 234.7 240 248 240L424 240C437.3 240 448 229.3 448 216C448 202.7 437.3 192 424 192L248 192C234.7 192 224 202.7 224 216zM248 288C234.7 288 224 298.7 224 312C224 325.3 234.7 336 248 336L424 336C437.3 336 448 325.3 448 312C448 298.7 437.3 288 424 288L248 288z"/>
                        </svg>
                      )}
                      {post.data.category === '영화' && (
                        <svg class="cat-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
                          <path d="M96 160C96 124.7 124.7 96 160 96L480 96C515.3 96 544 124.7 544 160L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 160zM144 432L144 464C144 472.8 151.2 480 160 480L192 480C200.8 480 208 472.8 208 464L208 432C208 423.2 200.8 416 192 416L160 416C151.2 416 144 423.2 144 432zM448 416C439.2 416 432 423.2 432 432L432 464C432 472.8 439.2 480 448 480L480 480C488.8 480 496 472.8 496 464L496 432C496 423.2 488.8 416 480 416L448 416zM144 304L144 336C144 344.8 151.2 352 160 352L192 352C200.8 352 208 344.8 208 336L208 304C208 295.2 200.8 288 192 288L160 288C151.2 288 144 295.2 144 304zM448 288C439.2 288 432 295.2 432 304L432 336C432 344.8 439.2 352 448 352L480 352C488.8 352 496 344.8 496 336L496 304C496 295.2 488.8 288 480 288L448 288zM144 176L144 208C144 216.8 151.2 224 160 224L192 224C200.8 224 208 216.8 208 208L208 176C208 167.2 200.8 160 192 160L160 160C151.2 160 144 167.2 144 176zM448 160C439.2 160 432 167.2 432 176L432 208C432 216.8 439.2 224 448 224L480 224C488.8 224 496 216.8 496 208L496 176C496 167.2 488.8 160 480 160L448 160z"/>
                        </svg>
                      )}
                      {post.data.title}
                    </p>
                    {themeConfig.date.dateOnRight && (
                      <div class={themeConfig.general.postListDottedDivider ? 'dotted-divider' : 'divider'} />
                    )}
                    {themeConfig.date.dateOnRight && <p class="date font-features">{shortDate(d)}</p>}
                  </div>
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    ))
  }
</div>
<div class="placeholder"></div>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .year-group {
    margin-bottom: 1rem;
  }

  .year-header {
    margin: 0 0 0.1rem;
    font-size: var(--font-size-s);
    color: var(--text-tertiary);
    letter-spacing: var(--spacing-s);
    opacity: 0.75;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }

  .year-header:hover {
    opacity: 1;
  }

  .year-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .year-count {
    font-size: 0.9em;
    opacity: 0.85;
  }

  .year-arrow {
    opacity: 0.5;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(90deg);
    flex-shrink: 0;
  }

  .year-arrow.collapsed {
    transform: rotate(0deg);
  }

  ul[data-year-list] {
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  a {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover a {
      opacity: 0.4;
    }

    ul:hover a:hover {
      opacity: 1;
    }

    ul:hover a:hover .divider {
      background-color: var(--text-tertiary);
      opacity: 0.75;
    }
    ul:hover a:hover .dotted-divider {
      color: var(--text-secondary);
    }
    ul:hover a:hover .date {
      color: var(--text-secondary);
      opacity: 1;
    }
  }

  .post-item {
    height: 2.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .post-item.date-left {
    justify-content: flex-start;
  }

  .post-item.date-left .title {
    flex: 1 1 auto;
    min-width: 0;
  }

  .post-item.date-left .date {
    margin-right: 0.75rem;
  }

  .title {
    margin: 0;
    flex-shrink: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .cat-icon {
    width: 0.75em;
    height: 0.75em;
    flex-shrink: 0;
    opacity: 0.65;
  }

  .date {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: var(--spacing-s);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .divider {
    flex: 1 1 auto;
    min-width: 3rem;
    margin: 0 0.25rem;
    height: 0.5px;
    background-color: var(--border);
  }

  .dotted-divider {
    flex: 1 1 3rem;
    min-width: 3rem;
    max-width: 100%;
    text-align: end;
    letter-spacing: 5px;
    height: 1.675rem;
    line-height: 1.675rem;
    overflow: hidden;
    color: var(--text-tertiary);
    opacity: 0.75;
  }

  .dotted-divider::after {
    content: '·····························································································································································';
    pointer-events: none;
  }

  .placeholder {
    height: 3rem;
  }

  @media (max-width: 768px) {
    .post-item {
      height: 1.875rem;
    }

    .dotted-divider {
      height: 1.875rem;
      line-height: 1.875rem;
    }

    .placeholder {
      height: 1.5rem;
    }
  }
</style>

<script is:inline>
  function initYearAccordion() {
    const currentYear = String(new Date().getFullYear())

    document.querySelectorAll('[data-year-list]').forEach((ul) => {
      const year = ul.getAttribute('data-year-list')
      const arrow = document.querySelector(`[data-year-arrow="${year}"]`)
      const isCurrentYear = year === currentYear

      if (isCurrentYear) {
        ul.style.maxHeight = ul.scrollHeight + 'px'
      } else {
        ul.style.maxHeight = '0'
        arrow?.classList.add('collapsed')
      }
    })

    document.querySelectorAll('[data-year-toggle]').forEach((header) => {
      header.addEventListener('click', () => {
        const year = header.getAttribute('data-year-toggle')
        const ul = document.querySelector(`[data-year-list="${year}"]`)
        const arrow = document.querySelector(`[data-year-arrow="${year}"]`)
        const isOpen = ul.style.maxHeight !== '0px' && ul.style.maxHeight !== ''

        if (isOpen) {
          ul.style.maxHeight = '0'
          arrow?.classList.add('collapsed')
        } else {
          ul.style.maxHeight = ul.scrollHeight + 'px'
          arrow?.classList.remove('collapsed')
        }
      })
    })
  }

  document.addEventListener('astro:page-load', initYearAccordion)
</script>
