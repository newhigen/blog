  {
    id: 'book',
    icon: true,
    iconPath:
      'M384 128C384 145.7 369.7 160 352 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L352 96C369.7 96 384 110.3 384 128zM384 384C384 401.7 369.7 416 352 416L128 416C110.3 416 96 401.7 96 384C96 366.3 110.3 352 128 352L352 352C369.7 352 384 366.3 384 384zM96 256C96 238.3 110.3 224 128 224L512 224C529.7 224 544 238.3 544 256C544 273.7 529.7 288 512 288L128 288C110.3 288 96 273.7 96 256zM544 512C544 529.7 529.7 544 512 544L128 544C110.3 544 96 529.7 96 512C96 494.3 110.3 480 128 480L512 480C529.7 480 544 494.3 544 512z'
  },
  {
    id: 'movie',
    icon: true,
    label: '영화·시리즈',
    iconPath:
      'M320 112C434.9 112 528 205.1 528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112zM320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM276.5 211.5C269.1 207 259.8 206.8 252.2 211C244.6 215.2 240 223.3 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4zM362 320L288 365.2L288 274.8L362 320z'
  },
  {
    id: 'writing',
    icon: true,
    iconPath:
      'M505 122.9L517.1 135C526.5 144.4 526.5 159.6 517.1 168.9L488 198.1L441.9 152L471 122.9C480.4 113.5 495.6 113.5 504.9 122.9zM273.8 320.2L408 185.9L454.1 232L319.8 366.2C316.9 369.1 313.3 371.2 309.4 372.3L250.9 389L267.6 330.5C268.7 326.6 270.8 323 273.7 320.1zM437.1 89L239.8 286.2C231.1 294.9 224.8 305.6 221.5 317.3L192.9 417.3C190.5 425.7 192.8 434.7 199 440.9C205.2 447.1 214.2 449.4 222.6 447L322.6 418.4C334.4 415 345.1 408.7 353.7 400.1L551 202.9C579.1 174.8 579.1 129.2 551 101.1L538.9 89C510.8 60.9 465.2 60.9 437.1 89zM152 128C103.4 128 64 167.4 64 216L64 488C64 536.6 103.4 576 152 576L424 576C472.6 576 512 536.6 512 488L512 376C512 362.7 501.3 352 488 352C474.7 352 464 362.7 464 376L464 488C464 510.1 446.1 528 424 528L152 528C129.9 528 112 510.1 112 488L112 216C112 193.9 129.9 176 152 176L264 176C277.3 176 288 165.3 288 152C288 138.7 277.3 128 264 128L152 128z'
  },
  { id: 'reading-write', label: '독서·글쓰기' },
  { id: 'work', label: '일·성장' },
  { id: 'thought', label: '생각' },
  { id: 'challenge', label: '100일글쓰기' }
]
---

<div class="tag-filter">
  <div class="tag-list">
    {
      filters.map((filter) => (
        <button class="tag-btn" data-filter={filter.id} title={filter.label ?? ''}>
          {filter.icon ? (
            <svg class="filter-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
              <path d={filter.iconPath} />
            </svg>
          ) : (
            <>#{filter.label}</>
          )}
        </button>
      ))
    }
  </div>
  <button class="tag-btn active" data-filter="all">All</button>
</div>

<script>
  interface FilterConfig {
    matchCategory?: string
    matchCategories?: string[]
    excludeCategories?: string[]
    matchTags?: string[]
  }

  const FILTER_MAP: Record<string, FilterConfig> = {
    book: { matchCategory: '책' },
    movie: { matchCategory: '영화·시리즈' },
    writing: { excludeCategories: ['책', '영화·시리즈'] },
    'reading-write': { matchTags: ['독서', '글쓰기'] },
    work: { matchTags: ['일', '성장'] },
    thought: { matchTags: ['생각'] },
    challenge: { matchTags: ['100일글쓰기챌린지'] }
  }

  function initTagFilter() {
    const filterEl = document.querySelector('.tag-filter')
    if (!filterEl) return

    const buttons = filterEl.querySelectorAll<HTMLButtonElement>('.tag-btn')
    const postItems = document.querySelectorAll<HTMLLIElement>('.post-list li[data-category], .post-list li[data-tags]')

    function setActive(filter: string) {
      buttons.forEach((btn) => btn.classList.toggle('active', btn.dataset.filter === filter))

      const config = FILTER_MAP[filter]
      postItems.forEach((item) => {
        if (filter === 'all') {
          item.style.display = ''
        } else {
          const category = item.dataset.category ?? ''
          const postTags = (item.dataset.tags ?? '')
            .split(',')
            .map((t) => t.trim())
            .filter(Boolean)

          let matches = false

          if (config?.excludeCategories) {
            // 특정 카테고리 제외 (writing 필터)
            matches = !config.excludeCategories.includes(category)
          } else if (config?.matchCategories) {
            // 특정 카테고리들 중 하나 표시 (movie 필터)
            matches = config.matchCategories.includes(category)
          } else if (config?.matchCategory) {
            // 특정 카테고리만 표시 (book 필터)
            matches = category === config.matchCategory
          } else if (config?.matchTags) {
            // 특정 태그 표시 (reading-write, work, thought, challenge 필터)
            matches = config.matchTags.some((t) => postTags.includes(t))
          }

          item.style.display = matches ? '' : 'none'
        }
      })

      document.querySelectorAll<HTMLElement>('.year-group').forEach((group) => {
        const visible = group.querySelectorAll<HTMLLIElement>('li[data-category], li[data-tags]')
        const count = [...visible].filter((li) => li.style.display !== 'none').length
        const countEl = group.querySelector<HTMLElement>('.year-count')
        if (countEl) countEl.textContent = `글 ${count}개`
        group.style.display = count === 0 ? 'none' : ''
      })
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all'
        const isAlreadyActive = btn.classList.contains('active')
        setActive(isAlreadyActive && filter !== 'all' ? 'all' : filter)
      })
    })
  }

  document.addEventListener('astro:page-load', initTagFilter)
</script>

<style>
  .tag-filter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .tag-list {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .tag-btn {
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-light);
    color: var(--text-tertiary);
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding: 0;
    padding-bottom: 0.05rem;
    cursor: pointer;
    letter-spacing: var(--spacing-s);
    transition:
      color 0.15s ease-out,
      border-color 0.15s ease-out;
    font-family: inherit;
    line-height: 1.5;
    display: flex;
    align-items: center;
    height: 1.5em;
  }

  .filter-icon {
    width: 1em;
    height: 1em;
    transition: opacity 0.15s ease-out;
  }

  .tag-btn:hover {
    color: var(--text-secondary);
  }

  .tag-btn.active {
    color: var(--text-primary);
    font-weight: var(--font-weight-regular);
    border-bottom-color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .tag-filter {
      margin-bottom: 0.625rem;
    }
  }
</style>
