---
import IndexLayout from '@/layouts/IndexLayout.astro'
import About from '@/components/widgets/About.astro'
import ReadingHeatmap from '@/components/widgets/ReadingHeatmap.astro'
import WritingHeatmap from '@/components/widgets/WritingHeatmap.astro'
import MovieHeatmap from '@/components/widgets/MovieHeatmap.astro'
import CombinedHeatmap from '@/components/widgets/CombinedHeatmap.astro'
import PostList from '@/components/widgets/PostList.astro'
import TagFilter from '@/components/widgets/TagFilter.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'

const posts = await getSortedFilteredPosts()
---

<IndexLayout title={themeConfig.site.title} description={themeConfig.site.description}>
  <About />

  <div class="heatmap-toggle-wrap">
    <div class="heatmap-toggle">
      <button class="toggle-btn active" id="btn-reading" title="독서">
        <svg class="heatmap-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
          <path d="M384 128C384 145.7 369.7 160 352 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L352 96C369.7 96 384 110.3 384 128zM384 384C384 401.7 369.7 416 352 416L128 416C110.3 416 96 401.7 96 384C96 366.3 110.3 352 128 352L352 352C369.7 352 384 366.3 384 384zM96 256C96 238.3 110.3 224 128 224L512 224C529.7 224 544 238.3 544 256C544 273.7 529.7 288 512 288L128 288C110.3 288 96 273.7 96 256zM544 512C544 529.7 529.7 544 512 544L128 544C110.3 544 96 529.7 96 512C96 494.3 110.3 480 128 480L512 480C529.7 480 544 494.3 544 512z" />
        </svg>
      </button>
      <button class="toggle-btn" id="btn-writing" title="글">
        <svg class="heatmap-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
          <path d="M505 122.9L517.1 135C526.5 144.4 526.5 159.6 517.1 168.9L488 198.1L441.9 152L471 122.9C480.4 113.5 495.6 113.5 504.9 122.9zM273.8 320.2L408 185.9L454.1 232L319.8 366.2C316.9 369.1 313.3 371.2 309.4 372.3L250.9 389L267.6 330.5C268.7 326.6 270.8 323 273.7 320.1zM437.1 89L239.8 286.2C231.1 294.9 224.8 305.6 221.5 317.3L192.9 417.3C190.5 425.7 192.8 434.7 199 440.9C205.2 447.1 214.2 449.4 222.6 447L322.6 418.4C334.4 415 345.1 408.7 353.7 400.1L551 202.9C579.1 174.8 579.1 129.2 551 101.1L538.9 89C510.8 60.9 465.2 60.9 437.1 89zM152 128C103.4 128 64 167.4 64 216L64 488C64 536.6 103.4 576 152 576L424 576C472.6 576 512 536.6 512 488L512 376C512 362.7 501.3 352 488 352C474.7 352 464 362.7 464 376L464 488C464 510.1 446.1 528 424 528L152 528C129.9 528 112 510.1 112 488L112 216C112 193.9 129.9 176 152 176L264 176C277.3 176 288 165.3 288 152C288 138.7 277.3 128 264 128L152 128z" />
        </svg>
      </button>
      <button class="toggle-btn" id="btn-movie" title="영화·시리즈">
        <svg class="heatmap-icon" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
          <path d="M320 112C434.9 112 528 205.1 528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112zM320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM276.5 211.5C269.1 207 259.8 206.8 252.2 211C244.6 215.2 240 223.3 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4zM362 320L288 365.2L288 274.8L362 320z" />
        </svg>
      </button>
      <button class="toggle-btn" id="btn-combined">같이</button>
    </div>
    <div id="heatmap-reading"><ReadingHeatmap compact /></div>
    <div id="heatmap-movie" style="display: none;"><MovieHeatmap compact /></div>
    <div id="heatmap-writing" style="display: none;"><WritingHeatmap compact /></div>
    <div id="heatmap-combined" style="display: none;"><CombinedHeatmap compact /></div>
  </div>

  <main>
    <TagFilter />
    <PostList posts={posts} />
  </main>
</IndexLayout>

<style>
  .heatmap-toggle-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 1rem;
  }

  @media (max-width: 430px) {
    .heatmap-toggle-wrap {
      margin-top: 0;
    }
  }
  .heatmap-toggle {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }
  .toggle-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--font-size-s);
    color: var(--text-tertiary);
    letter-spacing: var(--spacing-s);
    padding: 0;
    transition: color 0.15s ease-out;
    display: flex;
    align-items: center;
    outline: none;
  }
  .heatmap-icon {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }
  .toggle-btn.active {
    color: var(--text-primary);
  }
</style>

<script is:inline>
  function initHeatmapToggle() {
    const keys = ['reading', 'movie', 'writing', 'combined']
    const btns = {}
    const maps = {}
    for (const k of keys) {
      btns[k] = document.getElementById('btn-' + k)
      maps[k] = document.getElementById('heatmap-' + k)
    }
    if (!btns.reading || !btns.movie || !btns.writing || !btns.combined) return

    function show(key) {
      for (const k of keys) {
        maps[k].style.display = k === key ? '' : 'none'
        btns[k].classList.toggle('active', k === key)
      }
    }

    btns.reading.addEventListener('click', () => show('reading'))
    btns.movie.addEventListener('click', () => show('movie'))
    btns.writing.addEventListener('click', () => show('writing'))
    btns.combined.addEventListener('click', () => show('combined'))
  }
  document.addEventListener('astro:page-load', initHeatmapToggle)
</script>
